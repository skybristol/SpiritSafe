            "hash": "673bbd5a7ad8705b6f5706f9e2fabd248494b2bb",
            "datavalue": {
              "value": {
                "text": "Utilice el nombre que la tribu emplea para referirse a s\u00ed misma como etiqueta principal siempre que sea posible. Ap\u00f3yese en los sitios web oficiales del gobierno tribal. D\u00e9 preferencia a la autodenominaci\u00f3n de la tribu sobre los nombres asignados por gobiernos externos.",
                "language": "es"
              },
              "type": "monolingualtext"
            },
            "datatype": "monolingualtext"
          },
          "type": "statement",
          "id": "Q4$a29ab1bf-4dd1-f8c9-ff2f-726716c799c9",
          "rank": "normal"
